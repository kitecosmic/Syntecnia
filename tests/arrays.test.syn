-- Dogfood del Batch 5 (arrays + álgebra lineal) usando el test framework del Batch 3.
-- Correr con:  synsema test tests/arrays.test.syn

let tol be 0.000000001

-- ===== Construcción / introspección =====

test "construct matrices and inspect"
    let m be array([[1, 2], [3, 4]])
    assert_eq(shape(m), [2, 2])
    assert_eq(ndim(m), 2)
    assert_eq(size(m), 4)
    assert_eq(type_of(m), "array")
    assert_eq(identity(2), array([[1, 0], [0, 1]]))

-- ===== Aritmética vectorizada: `*` ELEMENTWISE ≠ matmul =====

test "star is elementwise, not matrix product"
    let a be array([[1, 2], [3, 4]])
    let i be array([[1, 0], [0, 1]])
    -- Hadamard (elementwise): a * i = [[1,0],[0,4]]
    assert_eq(a * i, array([[1, 0], [0, 4]]))
    -- producto matricial: matmul(a, i) = a
    assert_eq(matmul(a, i), a)
    -- y son distintos
    assert(a * i != matmul(a, i))

test "broadcasting and scalar ops"
    assert_eq(array([1, 2, 3]) + array([10, 20, 30]), array([11, 22, 33]))
    assert_eq(array([1, 2, 3]) * 2, array([2, 4, 6]))
    -- broadcasting [2,2] + [2]
    assert_eq(array([[1, 2], [3, 4]]) + array([10, 20]), array([[11, 22], [13, 24]]))

-- ===== Álgebra lineal: matmul, solve, inv =====

test "matmul known vector"
    assert_eq(matmul(array([[1, 2], [3, 4]]), array([[5, 6], [7, 8]])), array([[19, 22], [43, 50]]))

test "solve a linear system and verify A*x = b"
    let a be array([[2, 1], [1, 3]])
    let b be array([3, 4])
    let x be solve(a, b)
    -- A·x ≈ b  (residual chico)
    assert(norm(matmul(a, reshape(x, [2, 1])) - reshape(b, [2, 1])) < tol)
    assert(norm(x - array([1, 1])) < tol)

test "inverse: A_inv * A = identity"
    let a be array([[1, 2], [3, 4]])
    assert(norm(matmul(inv(a), a) - identity(2)) < tol)
    assert_eq(det(a), -2.0)

test "singular matrix errors (no silent NaN)"
    assert_error(() => inv(array([[1, 2], [2, 4]])))
    assert_error(() => solve(array([[1, 2], [2, 4]]), array([1, 2])))

-- ===== Reducciones por eje + norm/trace =====

test "reductions total and by axis"
    let m be array([[1, 2], [3, 4]])
    assert_eq(sum(m), 10.0)
    assert_eq(sum(m, 0), array([4, 6]))
    assert_eq(sum(m, 1), array([3, 7]))
    assert_eq(norm(array([3, 4])), 5.0)
    assert_eq(trace(m), 5.0)

-- ===== eig (combina con complex del Batch 4) =====

test "eig of symmetric matrix: eigenvalues real, sum = trace"
    let r be eig(array([[2, 1], [1, 2]]))
    -- autovalores 1 y 3 → suma = trace = 4; partes imaginarias ≈ 0 (simétrica)
    assert(abs((real(r.values[0]) + real(r.values[1])) - 4) < tol)
    assert(abs(imag(r.values[0])) + abs(imag(r.values[1])) < tol)
    assert(is_complex(r.values[0]))

-- ===== svd: reconstrucción U·diag(s)·Vt ≈ A =====

test "svd reconstructs the matrix"
    let a be array([[1, 2], [3, 4]])
    let r be svd(a)
    assert(norm(matmul(r.u * r.s, r.vt) - a) < tol)

-- ===== G1: las listas escalares siguen igual =====

test "G1: scalar list reductions unchanged"
    assert_eq(sum([1, 2, 3]), 6)
    assert_eq(mean([1, 2, 3]), 2.0)
    assert_eq(min(3, 5, 1), 1)
