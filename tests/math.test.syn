-- Dogfood del Batch 4 (completitud matemática) usando el test framework del Batch 3.
-- Ejercita complejos (Euler, raíces), funciones especiales (gamma/erf/beta) e
-- hiperbólicas, en el propio lenguaje. Correr con:  synsema test tests/math.test.syn

let tol be 0.000000001

task close(a, b)
    give abs(a - b) < tol

-- ===== Números complejos: constructor, aritmética, igualdad =====

test "complex constructor and display"
    assert_eq(text(complex(3, 2)), "3+2i")
    assert_eq(text(complex(3, -2)), "3-2i")
    assert_eq(type_of(complex(1, 2)), "complex")

test "complex arithmetic with real promotion"
    assert_eq(complex(1, 2) + complex(3, 4), complex(4, 6))
    assert_eq(2 * complex(0, 1), complex(0, 2))
    assert_eq(3 + complex(0, 2), complex(3, 2))
    assert_eq(complex(0, 1) ** 2, complex(-1, 0))

test "complex equality is Pythonic and unordered"
    assert(complex(3, 0) == 3)
    assert(complex(3, 2) != 3)
    assert_error(() => complex(1, 0) < complex(2, 0))

test "accessors: real, imag, abs, conj, arg"
    assert_eq(real(complex(3, 4)), 3.0)
    assert_eq(imag(complex(3, 4)), 4.0)
    assert_eq(abs(complex(3, 4)), 5.0)
    assert_eq(conj(complex(3, 4)), complex(3, -4))

-- ===== cmath: identidad de Euler y raíces =====

test "Euler identity: exp(i*pi) = -1"
    let z be exp(complex(0, pi))
    assert(close(real(z), -1))
    assert(close(imag(z), 0))

test "sqrt of -1 as complex is i"
    assert_eq(sqrt(complex(-1, 0)), complex(0, 1))
    -- pero sqrt(-1) REAL sigue siendo NaN (G1)
    assert(is_nan(sqrt(-1)))

-- ===== Funciones especiales (vectores publicados) =====

test "gamma matches factorial and sqrt(pi)"
    assert(close(gamma(5), 24))
    assert(close(gamma(0.5), 1.7724538509055159))

test "erf / erfc / beta vectors"
    assert(close(erf(1), 0.8427007929497149))
    assert_eq(erf(0), 0)
    assert_eq(erfc(0), 1)
    assert(close(beta(2, 3), 0.08333333333333333))

test "gamma rejects complex"
    assert_error(() => gamma(complex(1, 1)))

-- ===== Hiperbólicas =====

test "hyperbolics real and complex"
    assert_eq(sinh(0), 0)
    assert_eq(cosh(0), 1)
    assert(close(asinh(sinh(1)), 1))
    -- sinh(i) = i*sin(1)
    assert(close(imag(sinh(complex(0, 1))), 0.8414709848078965))
