# Template for `.env` — copy to `.env` (gitignored) and fill in real values.
# Synsema auto-loads `.env` from the working directory at startup.
# Resolution order: process environment > .env > the default passed to env()/secret().
# See .synsema-skill/secrets.md

PORT=8080
DATABASE_URL=postgres://localhost/dev

# Secrets: read with secret("NAME") — opaque and redacted everywhere.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
