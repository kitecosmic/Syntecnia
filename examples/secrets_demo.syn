-- Synsema: config by environment + LLM-proof secrets.
-- Run:  synsema run examples/secrets_demo.syn
-- See:  .synsema-skill/secrets.md  (and .env.example for a .env template)

intent: "Show env config and redacted, LLM-proof secrets"

-- Declare what we read, by name (deny-by-default, like net/file).
require env("PORT")
require secret("STRIPE_API_KEY")
require secret("STRIPE_WEBHOOK_SECRET")

-- env(): plain config. environ > .env > default. Here no env/.env → the default.
let port be env("PORT", 8080)
print("PORT = " + text(port))

-- secret(): opaque + redacted EVERYWHERE. The value is never printed/logged/serialized.
let api_key be secret("STRIPE_API_KEY", "sk_live_demo_value_never_prints")
print("api_key prints as: " + text(api_key))      -- secret(STRIPE_API_KEY)
print("type_of(api_key) = " + type_of(api_key))   -- secret

-- Concatenation propagates the taint: still a secret, still redacted.
let header_demo be "Authorization: " + api_key
print("concat stays: " + type_of(header_demo))    -- secret

-- bearer(): a tainted auth header value. Materialized only at the socket by fetch/http*.
-- (Shown here just to prove it stays redacted in user space.)
print("bearer prints as: " + text(bearer(api_key)))

-- Verify a webhook signature WITHOUT ever revealing the secret (constant-time).
let whsec be secret("STRIPE_WEBHOOK_SECRET", "whsec_demo")
let payload be "{\"id\":\"evt_123\"}"
let good_sig be hmac_sha256(payload, whsec)        -- the MAC is hex, not secret
print("computed MAC (not secret): " + good_sig)
print("verify good = " + text(verify_hmac(payload, good_sig, whsec)))
print("verify bad  = " + text(verify_hmac(payload, "deadbeef", whsec)))

-- constant_time_eq accepts a secret on either side.
print("ct_eq(secret, wrong) = " + text(constant_time_eq(api_key, "nope")))

-- The ONLY way to read plaintext is reveal() — needs `require reveal`, and every call
-- is written to a persistent audit log. Left commented on purpose: prefer the helpers
-- above and avoid reveal unless you truly must hand the raw value to legacy code.
--
-- require reveal
-- print(reveal(api_key))

print("done — no plaintext appeared above.")
