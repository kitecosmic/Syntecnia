__pycache__/
*.pyc
*.egg-info/
dist/
build/
.eggs/
*.json
!examples/*.json
# La extensión de editor son archivos .json legítimos (no caen bajo la regla de arriba).
!editors/**/*.json

# Rust
target/
**/*.rs.bk

# Privado — herramienta de testing interna (oráculo Python + harness differential).
# Se usa localmente; no va al repo público. (Los docs de proceso viven fuera del repo.)
conformance/

# Specs de implementación / docs de proceso: viven localmente, NO van al repo público.
specs/

# Arena de benchmark: comparativas locales (vs Go/Node/etc.), NO va al repo público.
synsema-arena/

# Estado/persistencia y daemons de runtime (fuera del repo, defensivo)
.synsema/

# Secretos: el .env real NUNCA va al repo (commitear .env.example con las claves
# sin valores como plantilla). Ver .synsema-skill/secrets.md.
.env
!.env.example
